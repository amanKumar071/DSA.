/****************************************************************

    Following is the class structure of the LinkedListNode class:

    template <typename T>
    class LinkedListNode
    {
    public:
        T data;
        LinkedListNode<T> *next;
        LinkedListNode(T data)
        {
            this->data = data;
            this->next = NULL;
        }
    };

*****************************************************************/

bool isPalindrome(LinkedListNode<int> *head) {
    
    vector<int>temp;
    LinkedListNode<int> * curr = head;

    while(curr){
        temp.push_back(curr->data);
        curr = curr->next;

    }

    int i=0; 
    int j=temp.size() - 1;

    while(i < j){
        if(temp[i] != temp[j]){
            return false;
           
        }
        i++;
        j--;
    }
    return true;

}


// 2nd  METHOD 

class Solution {
public:
    bool isPalindrome(ListNode* head) {
        ListNode* prev = NULL;
        ListNode* curr= head;
        ListNode* next = NULL;

        while(curr != NULL && curr ->next !=NULL){
            next = curr->next;
            curr->next = prev;
            prev = curr;
            next = curr;
        }

        if(head == prev) {
            return true;
        }
        
        return false;
    }
};

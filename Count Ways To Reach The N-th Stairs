#include <bits/stdc++.h> 
int countDistinctWays(int nStairs) {
    //  Write your code here.
    if(nStairs <= 1){
        return 1;

    }
    int mod = 1000000007;
    int prev2 = 1;
    int prev1 = 1;

    for(int i=2; i<=nStairs; i++){
        int current = ( prev2+ prev1) % mod;  
        prev2 = prev1;
        prev1 = current;
    }

    

    return prev1;
}
